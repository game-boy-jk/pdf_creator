MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=<ACCESS_KEY>
MINIO_SECRET_KEY=<SECRET_KEY>
MINIO_BUCKET=pdf-files
MINIO_SECURE=false
OUTPUT_PREFIX=generated/
CACHE_TTL_SEC=300
PDF_FONT_OBJECT_KEY=fonts/arial.ttf

# Optional fallback TTF/OTF font stored in the same S3 bucket.
# Use it when templates contain subset fonts that cannot render arbitrary values.
# PDF_FONT_OBJECT_KEY=fonts/arial.ttf

# Optional Spring Cloud Config compatible server.
# Request URL will be: {CONFIG_SERVER_URL}/{CONFIG_APP_NAME}/{CONFIG_PROFILE}/{CONFIG_LABEL}
# CONFIG_SERVER_URL=http://config-server:8888
# CONFIG_APP_NAME=pdf-creator
# CONFIG_PROFILE=default
# CONFIG_LABEL=main
# CONFIG_SERVER_TOKEN=<TOKEN>
# CONFIG_SERVER_TIMEOUT_SEC=3
# CONFIG_FAIL_FAST=false
